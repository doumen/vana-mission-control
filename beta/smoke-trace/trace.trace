          font-family:     'Syne', sans-serif;\n            color:           var(--vana-text);\n            background:      rgba(24,119,242,0.10);\n            border:          1px solid rgba(24,119,242,0.25);\n            transition:      opacity .2s, transform .2s;\n          ","onmouseover":"","onmouseout":""},"\n          ",["SPAN",{"class":"dashicons dashicons-facebook-alt","aria-hidden":"true","style":"font-size:16px;width:16px;height:16px;"}],"\n          Facebook        "],"\n              ",["A",{"href":"https://www.instagram.com/vanamadhuryamofficial/","target":"_blank","rel":"noopener noreferrer","class":"vana-community-link vana-community-link--ig","aria-label":"Instagram (Abre em nova aba)","style":"\n            display:         inline-flex;\n            align-items:     center;\n            gap:             7px;\n            padding:         8px 14px;\n            border-radius:   8px;\n            text-decoration: none;\n            font-weight:     700;\n            font-size:       0.85rem;\n            font-family:     'Syne', sans-serif;\n            color:           var(--vana-text);\n            background:      rgba(243,11,115,0.10);\n            border:          1px solid rgba(243,11,115,0.25);\n            transition:      opacity .2s, transform .2s;\n          ","onmouseover":"","onmouseout":""},"\n          ",["SPAN",{"class":"dashicons dashicons-instagram","aria-hidden":"true","style":"font-size:16px;width:16px;height:16px;"}],"\n          Instagram        "],"\n          "],"\n  "],"\n\n  \n"],"\n\n    ","\n    \n","\n",["DIV",{"class":"vana-drawer__overlay","id":"vana-agenda-overlay","data-vana-agenda-overlay":"","hidden":""}],"\n\n","\n",["DIV",{"id":"vana-agenda-drawer","class":"vana-drawer vana-drawer--agenda","data-vana-agenda-drawer":"","role":"dialog","aria-modal":"true","aria-label":"Agenda","hidden":""},"\n\n    ","\n    ",["DIV",{"class":"vana-drawer__header"},"\n        ",["SPAN",{"class":"vana-drawer__title"},"\n            