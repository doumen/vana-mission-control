<?php
/**
 * Single Template: vana_visit
 * Arquivo: single-vana_visit.php (raiz do tema)
 *
 * Responsabilidades:
 *   1. Autenticar e carregar o post vana_visit
 *   2. Ler metas do CPT (class-vana-visit-cpt.php) — sem recriar nada
 *   3. Decodificar _vana_visit_timeline_json → $visit_data
 *   4. Injetar <head> completo (PWA, OG, canonical)
 *   5. Renderizar Splash Screen (só em PWA standalone)
 *   6. Delegar renderização ao visit-template.php (partials)
 *
 * Metas consumidas (registradas pelo CPT):
 *   _vana_origin_key
 *   _vana_parent_tour_origin_key
 *   _vana_start_date
 *   _vana_tz
 *   _vana_youtube_id
 *   _vana_hero_fb_url
 *   _vana_visit_timeline_json
 *   _vana_timeline_updated_at
 *   _vana_timeline_hash
 */
defined('ABSPATH') || exit;
echo '<!-- VANA-PLUGIN-TEMPLATE-START -->';

/* ============================================================
   1. BOOTSTRAP DO POST
   ============================================================ */

// Garante contexto de post único
if (!have_posts()) {
    wp_redirect(home_url('/'));
    exit;
}
the_post();

$post_id = get_the_ID();

/* ============================================================
   2. LEITURA DE METAS (CPT já registrou — só consumimos)
   ============================================================ */

$origin_key      = (string) get_post_meta($post_id, '_vana_origin_key',              true);
$parent_tour_key = (string) get_post_meta($post_id, '_vana_parent_tour_origin_key',  true);
$start_date      = (string) get_post_meta($post_id, '_vana_start_date',              true);
$event_tz_str    = (string) get_post_meta($post_id, '_vana_tz',                      true);
$youtube_id      = (string) get_post_meta($post_id, '_vana_youtube_id',              true);
$hero_fb_url     = (string) get_post_meta($post_id, '_vana_hero_fb_url',             true);
$updated_at      = (string) get_post_meta($post_id, '_vana_timeline_updated_at',     true);
$timeline_hash   = (string) get_post_meta($post_id, '_vana_timeline_hash',           true);
$timeline_json   = (string) get_post_meta($post_id, '_vana_visit_timeline_json',     true);

// Timezone segura
try {
    $visit_tz = new DateTimeZone($event_tz_str ?: 'UTC');
} catch (Exception $e) {
    $visit_tz = new DateTimeZone('UTC');
}

// Decodifica o JSON do Trator
$visit_data = [];
if ($timeline_json !== '') {
    $decoded = json_decode($timeline_json, true);
    if (json_last_error() === JSON_ERROR_NONE && is_array($decoded)) {
        $visit_data = $decoded;
    }
}

/* ============================================================
   3. IDIOMA E DIA ATIVO
   ============================================================ */

$lang = (isset($_GET['lang']) && $_GET['lang'] === 'en') ? 'en' : 'pt';

// Dia ativo via URL (?day=YYYY-MM-DD) ou primeiro dia disponível
$days = is_array($visit_data['days'] ?? null) ? $visit_data['days'] : [];

$requested_day   = sanitize_text_field((string) ($_GET['v_day'] ?? ''));
$active_day      = [];
$active_day_date = '';

foreach ($days as $day) {
    if (!is_array($day)) continue;
    $d = (string) ($day['date_local'] ?? '');
    if ($requested_day !== '' && $d === $requested_day) {
        $active_day      = $day;
        $active_day_date = $d;
        break;
    }
    // Fallback: primeiro dia
    if ($active_day === [] && $d !== '') {
        $active_day      = $day;
        $active_day_date = $d;
    }
}

$active_vod_index = max(0, (int) ($_GET['vod'] ?? 0));

/* ============================================================
   4. META DADOS PARA <head>
   ============================================================ */

// Título da página
$page_title_pt = (string) ($visit_data['title_pt'] ?? get_the_title());
$page_title_en = (string) ($visit_data['title_en'] ?? $page_title_pt);
$page_title    = $lang === 'en' ? $page_title_en : $page_title_pt;

$site_name     = get_bloginfo('name') ?: 'Vana Madhuryam';
$canonical_url = get_permalink($post_id);

// OG Image: YouTube thumb → cover_url → thumbnail do post
$og_image = '';
if ($youtube_id !== '') {
    $og_image = 'https://i.ytimg.com/vi/' . $youtube_id . '/maxresdefault.jpg';
} elseif (!empty($visit_data['cover_url'])) {
    $og_image = esc_url_raw((string) $visit_data['cover_url']);
} elseif (has_post_thumbnail($post_id)) {
    $og_image = get_the_post_thumbnail_url($post_id, 'large');
}

$og_desc = $lang === 'en'
    ? (string) ($visit_data['description_en'] ?? $visit_data['description_pt'] ?? '')
    : (string) ($visit_data['description_pt'] ?? $visit_data['description_en'] ?? '');
$og_desc = wp_strip_all_tags($og_desc);

// URL do selo (logo) — filtrável pelo tema
$seal_url = apply_filters(
    'vana_seal_url',
    get_template_directory_uri() . '/assets/images/vana-seal.png'
);

// Cor tema PWA
$pwa_theme_color = apply_filters('vana_pwa_theme_color', '#0f172a');

/* ============================================================
   5. <head> COMPLETO
   ============================================================ */
?>
<!DOCTYPE html>
<html lang="<?php echo esc_attr($lang === 'en' ? 'en' : 'pt-BR'); ?>" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <!-- Título -->
  <title><?php echo esc_html($page_title . ' — ' . $site_name); ?></title>

  <!-- SEO -->
  <meta name="description"          content="<?php echo esc_attr($og_desc); ?>">
  <meta name="robots"               content="index, follow">
  <link rel="canonical"             href="<?php echo esc_url($canonical_url); ?>">

  <!-- Open Graph -->
  <meta property="og:type"          content="website">
  <meta property="og:site_name"     content="<?php echo esc_attr($site_name); ?>">
  <meta property="og:title"         content="<?php echo esc_attr($page_title); ?>">
  <meta property="og:description"   content="<?php echo esc_attr($og_desc); ?>">
  <meta property="og:url"           content="<?php echo esc_url($canonical_url); ?>">
  <?php if ($og_image): ?>
  <meta property="og:image"         content="<?php echo esc_url($og_image); ?>">
  <meta property="og:image:width"   content="1280">
  <meta property="og:image:height"  content="720">
  <?php endif; ?>

  <!-- Twitter Card -->
  <meta name="twitter:card"         content="summary_large_image">
  <meta name="twitter:title"        content="<?php echo esc_attr($page_title); ?>">
  <meta name="twitter:description"  content="<?php echo esc_attr($og_desc); ?>">
  <?php if ($og_image): ?>
  <meta name="twitter:image"        content="<?php echo esc_url($og_image); ?>">
  <?php endif; ?>

  <!-- PWA — Web App Manifest -->
  <link rel="manifest"
        href="<?php echo esc_url(
            add_query_arg(['vana_manifest' => '1', 'visit_id' => $origin_key],
            home_url('/'))
        ); ?>">

  <!-- PWA — Theme color (barra do browser mobile) -->
  <meta name="theme-color"          content="<?php echo esc_attr($pwa_theme_color); ?>">
  <meta name="theme-color"
        media="(prefers-color-scheme: light)"
        content="<?php echo esc_attr($pwa_theme_color); ?>">

  <!-- PWA — iOS -->
  <meta name="apple-mobile-web-app-capable"          content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title"
        content="<?php echo esc_attr($site_name); ?>">
  <link rel="apple-touch-icon"
        href="<?php echo esc_url($seal_url); ?>">

  <!-- Favicon -->
  <link rel="icon" type="image/png"
        href="<?php echo esc_url($seal_url); ?>">

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://www.youtube-nocookie.com">
  <link rel="preconnect" href="https://www.facebook.com">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;900&family=Questrial&display=swap"
        rel="stylesheet">

  <!-- Dashicons (WordPress core) -->
  <?php wp_print_styles('dashicons'); ?>

  <!-- Structured Data (JSON-LD) -->
  <script type="application/ld+json">
  <?php echo wp_json_encode([
      '@context'    => 'https://schema.org',
      '@type'       => 'Event',
      'name'        => $page_title,
      'description' => $og_desc,
      'startDate'   => $start_date ?: $active_day_date,
      'location'    => [
          '@type' => 'Place',
          'name'  => (string) ($active_day['hero']['location']['name'] ?? 'Vrindavan'),
      ],
      'organizer'   => [
          '@type' => 'Organization',
          'name'  => $site_name,
          'url'   => 'https://www.youtube.com/@vanamadhuryamofficial',
      ],
      'image'       => $og_image ?: $seal_url,
      'url'         => $canonical_url,
  ], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES); ?>
  </script>

  <!-- Splash Screen CSS (inline — crítico, sem FOUC) -->
  <style>
    #vana-splash {
      position:        fixed;
      inset:           0;
      z-index:         99999;
      display:         flex;
      flex-direction:  column;
      align-items:     center;
      justify-content: center;
      gap:             24px;
      background:      linear-gradient(160deg, #0f172a 0%, #1e1a0e 60%, #0f172a 100%);
      opacity:         1;
      transition:      opacity 0.5s ease;
      /* Só visível se PWA standalone — JS remove se não for standalone */
    }

    #vana-splash__seal {
      width:      180px;
      height:     180px;
      object-fit: contain;
      /* Glow dourado */
      filter:     drop-shadow(0 0 24px rgba(255, 217, 6, 0.55))
                  drop-shadow(0 0 8px  rgba(255, 217, 6, 0.35));
      animation:  vana-seal-pulse 2s ease-in-out infinite;
    }

    @keyframes vana-seal-pulse {
      0%, 100% { filter:
        drop-shadow(0 0 24px rgba(255, 217, 6, 0.55))
        drop-shadow(0 0 8px  rgba(255, 217, 6, 0.35));
      }
      50% { filter:
        drop-shadow(0 0 40px rgba(255, 217, 6, 0.80))
        drop-shadow(0 0 16px rgba(255, 217, 6, 0.55));
      }
    }

    #vana-splash__title {
      font-family:    'Syne', sans-serif;
      font-weight:    900;
      font-size:      clamp(1rem, 4vw, 1.3rem);
      color:          #FFD906;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      opacity:        0.9;
    }

    #vana-splash__loader {
      width:         48px;
      height:        4px;
      border-radius: 2px;
      background:    rgba(255,217,6,.2);
      overflow:      hidden;
      position:      relative;
    }

    #vana-splash__loader::after {
      content:       '';
      position:      absolute;
      left:          -100%;
      top:           0;
      width:         60%;
      height:        100%;
      background:    #FFD906;
      border-radius: 2px;
      animation:     vana-loader-slide 1.2s ease-in-out infinite;
    }

    @keyframes vana-loader-slide {
      0%   { left: -60%; }
      100% { left: 110%; }
    }

    /* Oculta conteúdo principal até splash sair */
    body.vana-splash-active #vana-page-root {
      visibility: hidden;
    }
  </style>

</head>
<body class="vana-splash-active vana-visit-page">

<!-- ============================================================
     SPLASH SCREEN
     Visível apenas em PWA standalone. JS remove em < 2s.
     ============================================================ -->
<div id="vana-splash" role="status" aria-live="polite"
     aria-label="<?php echo esc_attr($lang === 'en' ? 'Loading…' : 'Carregando…'); ?>">

  <img
    id="vana-splash__seal"
    src="<?php echo esc_url($seal_url); ?>"
    alt="<?php echo esc_attr($site_name); ?>"
    width="180"
    height="180"
  >

  <div id="vana-splash__title">
    <?php echo esc_html($site_name); ?>
  </div>

  <div id="vana-splash__loader" aria-hidden="true"></div>

</div>

<!-- ============================================================
     CONTEÚDO PRINCIPAL
     ============================================================ -->
<div id="vana-page-root">

  <?php
  /* ----------------------------------------------------------
     Injeta variáveis para os partials e delega ao orquestrador
     ---------------------------------------------------------- */
  $GLOBALS['_vana_visit'] = [
      'post_id'           => $post_id,
      'origin_key'        => $origin_key,
      'parent_tour_key'   => $parent_tour_key,
      'start_date'        => $start_date,
      'visit_tz'          => $visit_tz,
      'youtube_id'        => $youtube_id,
      'hero_fb_url'       => $hero_fb_url,
      'updated_at'        => $updated_at,
      'timeline_hash'     => $timeline_hash,
      'visit_data'        => $visit_data,
      'days'              => $days,
      'active_day'        => $active_day,
      'active_day_date'   => $active_day_date,
      'active_vod_index'  => $active_vod_index,
      'lang'              => $lang,
      'seal_url'          => $seal_url,
      'page_title'        => $page_title,
      'og_image'          => $og_image,
  ];

  // Delega ao orquestrador de partials
  $tpl = get_stylesheet_directory() . '/templates/visit/visit-template.php';
  if (file_exists($tpl)) {
      include $tpl;
  } else {
      echo '<p style="padding:40px;text-align:center;color:#ef4444;">';
      echo esc_html($lang === 'en'
          ? 'Template not found. Contact the administrator.'
          : 'Template não encontrado. Contate o administrador.');
      echo '</p>';
  }
  ?>

</div>
<!-- /#vana-page-root -->

<!-- ============================================================
     SPLASH SCREEN — CONTROLE JS
     ============================================================ -->
<script>
(function () {
  'use strict';

  var splash  = document.getElementById('vana-splash');
  var root    = document.getElementById('vana-page-root');
  var body    = document.body;

  // Detecta modo standalone (PWA instalado)
  var isStandalone = (
    window.matchMedia('(display-mode: standalone)').matches ||
    window.navigator.standalone === true
  );

  function hideSplash() {
    if (!splash) return;
    splash.style.opacity    = '0';
    splash.style.transition = 'opacity 0.5s ease';
    setTimeout(function () {
      splash.style.display = 'none';
      splash.setAttribute('aria-hidden', 'true');
      body.classList.remove('vana-splash-active');
      if (root) root.style.visibility = 'visible';
    }, 500);
  }

  if (!isStandalone) {
    // Não é PWA standalone: remove splash imediatamente
    if (splash) splash.style.display = 'none';
    body.classList.remove('vana-splash-active');
    if (root) root.style.visibility = 'visible';
    return;
  }

  // É PWA standalone: exibe splash por 1.8s depois fecha
  // (o conteúdo já está carregado — efeito é puramente visual)
  var HOLD_MS = 1800;

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () {
      setTimeout(hideSplash, HOLD_MS);
    });
  } else {
    setTimeout(hideSplash, HOLD_MS);
  }

}());
</script>

</body>
</html>
