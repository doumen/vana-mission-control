        <a id="vanaModalExternalLink" href="#" target="_blank"
           rel="noopener noreferrer"
           style="display:none;background:var(--vana-blue);color:#fff;
                  padding:10px 20px;border-radius:6px;
                  text-decoration:none;font-weight:700;">
          <?php echo esc_html($lbl_open_orig); ?>
