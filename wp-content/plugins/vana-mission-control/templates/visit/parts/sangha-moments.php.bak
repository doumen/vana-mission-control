<?php if (!defined('VANA_MODAL_RENDERED')): define('VANA_MODAL_RENDERED', true); ?>
<div class="vana-modal" id="vanaSubmissionModal"
     aria-hidden="true" role="dialog" aria-modal="true">
  <div class="vana-modal__backdrop" data-vana-modal-close="1"></div>
