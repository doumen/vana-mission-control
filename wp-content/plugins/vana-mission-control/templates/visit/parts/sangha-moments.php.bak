    <!-- v2: suporte a múltiplas fotos no modal via data-media-items -->
    <div class="vana-modal__media"  id="vanaModalMedia"></div>
    <div class="vana-modal__body">
      <p id="vanaModalKicker"
         style="color:var(--vana-orange);font-weight:800;
