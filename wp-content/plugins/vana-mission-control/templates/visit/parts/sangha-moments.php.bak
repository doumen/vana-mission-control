<?php
/**
 * Partial: Sangha Moments
 * Arquivo: templates/visit/parts/sangha-moments.php
 * Version: 2.0.0
 *
 * Fonte: CPT vana_submission (post_status = publish)
 * Formulário: shortcode [vana_oferenda_form] → REST POST /vana/v1/checkin
 *
 * Variáveis esperadas do _bootstrap.php:
 *   $lang, $visit_id, $active_day_date
 */
defined('ABSPATH') || exit;

// ── i18n ──────────────────────────────────────────────────────
$lbl_section  = vana_t('sangha.section', $lang);
$lbl_subtitle = vana_t('sangha.subtitle', $lang);
$lbl_anon     = vana_t('sangha.anon', $lang);
$lbl_silent   = vana_t('sangha.silent', $lang);
$lbl_open_orig= vana_t('sangha.open_link', $lang);
$lbl_photo_b  = vana_t('sangha.badge.photo', $lang);
$lbl_video_b  = vana_t('sangha.badge.video', $lang);
$lbl_msg_b    = vana_t('sangha.badge.message', $lang);

// ── Query: submissions aprovadas desta visita ─────────────────
$submissions = new WP_Query([
    'post_type'      => 'vana_submission',
    'post_status'    => 'publish',
    'posts_per_page' => 48,
    'meta_query'     => [[
        'key'     => '_visit_id',
        'value'   => $visit_id,
        'compare' => '=',
        'type'    => 'NUMERIC',
    ]],
]);

if (!function_exists('_vana_fmt_date')) {
    function _vana_fmt_date(int $ts): string {
        return $ts ? wp_date('d/m/Y', $ts) : '';
    }
}
?>

<!-- ============================================================
     SEÇÃO SANGHA
     ============================================================ -->
<section
  id="vana-section-sangha"
  class="vana-section vana-section--sangha"
  aria-labelledby="vana-sangha-heading"
  style="padding-top:8px;"
>

  <!-- Cabeçalho -->
  <h2 class="vana-section-title" id="vana-sangha-heading">
    <span class="dashicons dashicons-heart"
          aria-hidden="true"
          style="font-size:1.6rem;width:auto;height:auto;
                 color:var(--vana-pink);margin-right:8px;
                 vertical-align:middle;"></span>
    <?php echo esc_html($lbl_section); ?>
  </h2>
  <p style="color:var(--vana-muted);font-size:1.05rem;margin:-10px 0 28px;">
    <?php echo esc_html($lbl_subtitle); ?>
  </p>

  <!-- ══════════════════════════════════════════════════════════
       WALL de momentos aprovados
       ══════════════════════════════════════════════════════════ -->
  <?php if ($submissions->have_posts()): ?>
  <div class="vana-sangha-wall" role="list">

    <?php while ($submissions->have_posts()): $submissions->the_post();
      $sid       = get_the_ID();
      $name_raw  = (string) get_post_meta($sid, '_sender_display_name', true);
      $name      = trim($name_raw) !== '' ? trim($name_raw) : $lbl_anon;
      $msg       = wp_strip_all_tags((string) get_post_meta($sid, '_message', true));
      $ts        = (int) get_post_meta($sid, '_submitted_at', true);
      $pub_city  = (string) get_post_meta($sid, '_vana_public_user_city', true);
      $date_label= $ts ? _vana_fmt_date($ts) : '';

      // ── Lê _media_items (schema v2) com fallback para v1 ──
      $media_items = [];
      $raw_items   = get_post_meta($sid, '_media_items', true);

      if (!empty($raw_items)) {
          // Schema v2 — array serializado pelo Vana_Submission_CPT
          $media_items = is_array($raw_items)
              ? $raw_items
              : (json_decode($raw_items, true) ?? []);
      } else {
          // Fallback v1 — metas legadas
          $img_v1 = esc_url((string) get_post_meta($sid, '_image_url',    true));
          $ext_v1 = (string)          get_post_meta($sid, '_external_url', true);
          if ($img_v1)  $media_items[] = ['type' => 'image', 'url' => $img_v1,  'r2_key' => ''];
          if ($ext_v1)  $media_items[] = ['type' => 'video', 'url' => $ext_v1,  'r2_key' => ''];
      }

      // ── Primeiro item de mídia para o card ──
      $first_image = '';
      $first_ext   = '';
      foreach ($media_items as $item) {
          if ($item['type'] === 'image' && $first_image === '') {
              $first_image = esc_url($item['url']);
          }
          if ($item['type'] === 'video' && $first_ext === '') {
              $first_ext = $item['url'];
          }
      }

      // ── Thumb de vídeo ──
      $video_thumb   = '';
      $provider_type = '';
      if ($first_ext !== '') {
          if (preg_match(
              '%(?:youtube(?:-nocookie)?\.com/(?:[^/]+/.+/|(?:v|e(?:mbed)?)/|.*[?&]v=)|youtu\.be/)([^"&?/ ]{11})%i',
              $first_ext, $ym
          )) {
              $video_thumb   = "https://img.youtube.com/vi/{$ym[1]}/hqdefault.jpg";
              $provider_type = 'youtube';
          } elseif (strpos($first_ext, 'drive.google.com') !== false) {
              if (preg_match('~\/d\/([a-zA-Z0-9_-]+)~', $first_ext, $dm)) {
                  $video_thumb = "https://drive.google.com/thumbnail?id={$dm[1]}&sz=w400";
              }
              $provider_type = 'drive';
          } elseif (
              strpos($first_ext, 'facebook.com') !== false ||
              strpos($first_ext, 'fb.watch')     !== false
          ) {
              $video_thumb   = 'FB_VIDEO';
              $provider_type = 'facebook';
          }
      }

      $is_text_only = (!$first_image && !$video_thumb);
      $moment_class = 'vana-moment' . ($is_text_only ? ' vana-moment--text-only' : '');
      $initial      = mb_strtoupper(mb_substr($name, 0, 1));
      $kicker       = vana_t('sangha.kicker', $lang);
      if ($first_ext !== '') {
          $badge_label = $lbl_video_b;
          $badge_icon  = 'dashicons-video-alt3';
      } elseif ($first_image !== '') {
          $badge_label = $lbl_photo_b;
          $badge_icon  = 'dashicons-format-image';
      } else {
          $badge_label = $lbl_msg_b;
          $badge_icon  = 'dashicons-format-quote';
      }

      // ── Serializa media_items para o modal ──
      $media_json = esc_attr(wp_json_encode($media_items));
    ?>

    <article class="<?php echo esc_attr($moment_class); ?>" role="listitem">
      <button
        type="button"
        class="vana-moment-btn"
        data-vana-modal-open="1"
        data-vana-sangha-item="1"
        data-kicker="<?php echo esc_attr($kicker); ?>"
        data-title="<?php echo esc_attr($name); ?>"
        data-message="<?php echo esc_attr($msg); ?>"
        data-image="<?php echo esc_attr($first_image); ?>"
        data-external-url="<?php echo esc_attr($first_ext); ?>"
        data-media-items="<?php echo $media_json; ?>"
        aria-label="<?php echo esc_attr($kicker . ' — ' . $name); ?>"
      >
        <div class="vana-moment-inner">
          <div class="vana-moment-user">
            <div class="vana-moment-avatar" aria-hidden="true">
              <?php echo esc_html($initial); ?>
            </div>
            <div class="vana-moment-name"><?php echo esc_html($name); ?></div>
          </div>
          <?php if ($msg): ?>
            <div class="vana-moment-text"><?php echo esc_html($msg); ?></div>
          <?php endif; ?>
        </div>

        <?php if ($first_image): ?>
          <div class="vana-moment-media">
            <img src="<?php echo $first_image; ?>"
                 alt="<?php echo esc_attr(vana_t('sangha.photo_alt', $lang)); ?>"
                 loading="lazy">
          </div>

        <?php elseif ($video_thumb): ?>
          <div class="vana-moment-media"
               style="position:relative;background:#f1f5f9;border-radius:12px;
                      overflow:hidden;aspect-ratio:16/9;display:flex;
                      align-items:center;justify-content:center;">
            <?php if ($video_thumb === 'FB_VIDEO'): ?>
              <div style="position:absolute;inset:0;background:#1877F2;
                          display:flex;align-items:center;justify-content:center;
                          flex-direction:column;color:#fff;">
                <span class="dashicons dashicons-facebook-alt"
                      style="font-size:40px;width:40px;height:40px;"></span>
                <small style="font-weight:bold;margin-top:5px;">Facebook Video</small>
              </div>
            <?php else: ?>
              <img src="<?php echo esc_url($video_thumb); ?>"
                   alt="Video"
                   style="width:100%;height:100%;object-fit:cover;opacity:.8;"
                   loading="lazy">
              <div style="position:absolute;top:50%;left:50%;
                          transform:translate(-50%,-50%);
                          color:#fff;font-size:40px;
                          text-shadow:0 2px 10px rgba(0,0,0,.3);"
                   aria-hidden="true">
                <span class="dashicons dashicons-controls-play"></span>
              </div>
            <?php endif; ?>
          </div>
        <?php endif; ?>

        <div class="vana-moment-footer">
          <span class="vana-moment-badge">
            <span class="dashicons <?php echo esc_attr($badge_icon); ?>"
                  aria-hidden="true"></span>
            <?php echo esc_html($badge_label); ?>
          </span>
          <?php if ($pub_city): ?>
            <span style="display:flex;align-items:center;gap:5px;
                         color:var(--vana-muted);font-size:.8rem;font-weight:800;">
              <span class="dashicons dashicons-location"
                    style="font-size:14px;color:var(--vana-pink);"
                    aria-hidden="true"></span>
              <?php echo esc_html($pub_city); ?>
            </span>
          <?php else: ?>
            <span style="color:var(--vana-muted);font-size:.8rem;">
              <?php echo esc_html($date_label); ?>
            </span>
          <?php endif; ?>
        </div>
      </button>
    </article>

    <?php endwhile; wp_reset_postdata(); ?>
  </div><!-- /.vana-sangha-wall -->
  <?php endif; // have_posts ?>

  <!-- ══════════════════════════════════════════════════════════
       FORMULÁRIO — shortcode v2
       Substitui o <form id="vanaCheckinForm"> legado
       ══════════════════════════════════════════════════════════ -->
  <div id="form-oferenda" style="margin-top:40px;">
    <?php
    echo do_shortcode(
        sprintf(
            '[vana_oferenda_form visit_id="%d" lang="%s"]',
            (int) $visit_id,
            esc_attr($lang)
        )
    );
    ?>
  </div>

</section>

<!-- ============================================================
     MODAL — Sangha (compartilhado com gallery.php)
