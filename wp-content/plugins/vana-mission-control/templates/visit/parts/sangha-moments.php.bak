<!-- ============================================================
     JS — Modal apenas (submit removido → oferenda-form.js)
     ============================================================ -->
<script>
(function () {
  'use strict';

  /* ── Utilitários ──────────────────────────────────────────── */
  function parseYTId(url) {
    try {
      var u = new URL(url);
      if (u.hostname.includes('youtu.be'))
        return u.pathname.replace('/', '');
      var v = u.searchParams.get('v');
      if (v) return v;
      var m = u.pathname.match(/\/shorts\/([^\/]+)/);
      return (m && m[1]) ? m[1] : '';
    } catch (e) { return ''; }
  }
/* ── Render de um item de mídia individual ────────────────── */
function renderMediaItem(item, idx, total) {
  if (item.type === 'image') {
    return '<div class="vana-media-container" style="background:#000;'
         + 'display:flex;align-items:center;justify-content:center;">'
         + '<img src="' + item.url + '" alt="Foto ' + (idx + 1) + '" loading="lazy"'
         + ' style="max-width:100%;max-height:70vh;object-fit:contain;">'
         + '</div>';
  }

  var url = item.url || '';

  // YouTube
  var ytid = parseYTId(url);
  if (ytid) {
    // Só autoplay no primeiro item
    var autoplay = idx === 0 ? '?autoplay=1' : '?autoplay=0';
    return '<div class="vana-embed">'
         + '<iframe src="https://www.youtube.com/embed/' + ytid + autoplay
         + '" allowfullscreen allow="autoplay;encrypted-media;"></iframe></div>';
  }

  // Facebook
  if (url.includes('facebook.com') || url.includes('fb.watch')) {
    return '<div class="vana-embed">'
         + '<iframe src="https://www.facebook.com/plugins/video.php?href='
         + encodeURIComponent(url) + '&show_text=0&width=1200"'
         + ' scrolling="no" allowfullscreen allow="autoplay;encrypted-media;"></iframe></div>';
  }

  // Google Drive
  var dm = url.match(/d\/([a-zA-Z0-9_-]+)/);
  if (dm) {
    return '<div class="vana-embed">'
         + '<iframe src="https://drive.google.com/file/d/' + dm[1]
         + '/preview" allow="autoplay"></iframe></div>';
  }

  // Fallback link
  return '<div style="padding:40px;text-align:center;">'
       + '<a href="' + url + '" target="_blank" rel="noopener noreferrer"'
       + ' style="color:var(--vana-gold);font-weight:700;">Abrir link →</a></div>';
}

/* ── Navega para slide N ──────────────────────────────────── */
function goToSlide(mediaEl, idx) {
  mediaEl.querySelectorAll('.vana-modal-gallery__item').forEach(function(el, i) {
    el.classList.toggle('is-active', i === idx);
  });
  mediaEl.querySelectorAll('.vana-modal-gallery__dot').forEach(function(d, i) {
    d.classList.toggle('is-active', i === idx);
  });
}

  /* ── Render modal — suporta múltiplos media_items (v2) ────── */
function renderSangha(data) {
  var mediaEl = document.getElementById('vanaModalMedia');
  var msgEl   = document.getElementById('vanaModalMessage');
  if (!mediaEl || !msgEl) return;

  var ext     = (data.externalUrl || '').trim();
  var image   = (data.image       || '').trim();
  var msg     = (data.message     || '').trim();

  // Parse media_items v2
  var mediaItems = [];
  try { mediaItems = JSON.parse(data.mediaItems || '[]'); } catch (e) {}

  // Separa por tipo
  var images = mediaItems.filter(function(i) { return i.type === 'image'; });
  var videos = mediaItems.filter(function(i) { return i.type === 'video'; });

  // Se não há media_items mas tem campos legados v1, converte
  if (mediaItems.length === 0) {
    if (image) images = [{ type: 'image', url: image }];
    if (ext)   videos = [{ type: 'video', url: ext   }];
  }

  var allMedia = videos.concat(images); // vídeos primeiro
  mediaEl.innerHTML = '';
  msgEl.innerHTML   = '';

  // ── Sem nenhuma mídia ──────────────────────────────────────
  if (allMedia.length === 0) {
    mediaEl.innerHTML =
      '<div style="padding:60px;text-align:center;width:100%;">'
      + '<span class="dashicons dashicons-format-quote"'
      + ' style="font-size:4rem;color:var(--vana-gold);opacity:.5;"></span></div>';

  // ── Mídia única ────────────────────────────────────────────
  } else if (allMedia.length === 1) {
    mediaEl.innerHTML = renderMediaItem(allMedia[0], 0, 1);

  // ── Múltiplas mídias — carrossel unificado ─────────────────
  } else {
    var html = '<div class="vana-modal-gallery">';
    allMedia.forEach(function(item, i) {
      html += '<div class="vana-modal-gallery__item' + (i === 0 ? ' is-active' : '') + '">'
            + renderMediaItem(item, i, allMedia.length)
            + '</div>';
    });
    html += '</div>';

    // Dots
    html += '<div class="vana-modal-gallery__dots">';
    allMedia.forEach(function(item, i) {
      var icon = item.type === 'video' ? '▶' : '●';
      html += '<button type="button" class="vana-modal-gallery__dot'
            + (i === 0 ? ' is-active' : '') + '" data-idx="' + i + '">'
            + icon + '</button>';
    });
    html += '</div>';

    mediaEl.innerHTML = html;

    // Bind dots
    mediaEl.querySelectorAll('.vana-modal-gallery__dot').forEach(function(dot) {
      dot.addEventListener('click', function() {
        goToSlide(mediaEl, parseInt(this.dataset.idx, 10));
      });
    });

    // Swipe mobile
    (function() {
      var gallery = mediaEl.querySelector('.vana-modal-gallery');
      if (!gallery) return;
      var startX = 0;
      gallery.addEventListener('touchstart', function(e) {
        startX = e.touches[0].clientX;
      }, { passive: true });
      gallery.addEventListener('touchend', function(e) {
        var diff = startX - e.changedTouches[0].clientX;
        if (Math.abs(diff) < 40) return;
        var items = mediaEl.querySelectorAll('.vana-modal-gallery__item');
        var cur   = Array.from(items).findIndex(function(el) {
          return el.classList.contains('is-active');
        });
        var next = diff > 0
          ? Math.min(cur + 1, items.length - 1)
          : Math.max(cur - 1, 0);
        if (next !== cur) goToSlide(mediaEl, next);
      }, { passive: true });
    }());
  }

  // ── Corpo: texto ───────────────────────────────────────────
  var body = '';
  if (msg) {
    body += '<div style="white-space:pre-wrap;font-size:1.05rem;'
          + 'line-height:1.6;color:var(--vana-text);">' + msg + '</div>';
  }
  if (!msg && allMedia.length === 0) {
    body += '<div style="text-align:center;font-style:italic;'
          + 'color:var(--vana-muted);padding:20px 0;">'
          + '<?php echo esc_js($lbl_silent); ?></div>';
  }
  msgEl.innerHTML = body;

  document.getElementById('vanaModalKicker').textContent =
    data.kicker || '<?php echo esc_js($lang === "en" ? "Sangha Realization" : "Relato da Sangha"); ?>';
  document.getElementById('vanaModalTitle').textContent =
    data.title || '<?php echo esc_js($lbl_anon); ?>';

  // Link externo — usa o primeiro vídeo, se houver
  var linkEl    = document.getElementById('vanaModalExternalLink');
  var firstVidUrl = videos.length > 0 ? (videos[0].url || '') : '';
  if (firstVidUrl) {
    var ytid2  = parseYTId(firstVidUrl);
    var isFB2  = firstVidUrl.includes('facebook.com') || firstVidUrl.includes('fb.watch');
    var isDrv2 = firstVidUrl.includes('drive.google.com');
    linkEl.href          = firstVidUrl;
    linkEl.style.display = 'inline-block';
    linkEl.textContent   = ytid2  ? '<?php echo esc_js($lang === "en" ? "Watch on YouTube →" : "Ver no YouTube →"); ?>'
                         : isFB2  ? '<?php echo esc_js($lang === "en" ? "Watch on Facebook →" : "Ver no Facebook →"); ?>'
                         : isDrv2 ? '<?php echo esc_js($lang === "en" ? "Watch on Drive →" : "Ver no Drive →"); ?>'
                         :          '<?php echo esc_js($lbl_open_orig); ?>';
  } else {
    linkEl.style.display = 'none';
  }
}

  /* ── Modal ────────────────────────────────────────────────── */
  (function () {
    var modal   = document.getElementById('vanaSubmissionModal');
    var btnPrev = document.getElementById('vanaModalPrev');
    var btnNext = document.getElementById('vanaModalNext');
    if (!modal) return;

    var set = [], idx = -1;

    function nav(d) {
      if (set.length <= 1) return;
      idx = (idx + d + set.length) % set.length;
      renderSangha(set[idx].dataset);
    }

    document.addEventListener('click', function (e) {
      var sb = e.target.closest('[data-vana-sangha-item="1"]');
      if (sb) {
        var isGallery = !!sb.dataset.vanaGalleryItem;
        var selector  = isGallery
          ? '[data-vana-sangha-item="1"][data-vana-gallery-item="1"]'
          : '[data-vana-sangha-item="1"]:not([data-vana-gallery-item])';
        set = Array.from(document.querySelectorAll(selector));
        idx = set.indexOf(sb);
        renderSangha(sb.dataset);
        modal.classList.add('is-active');
        modal.setAttribute('aria-hidden', 'false');
        if (btnPrev) btnPrev.style.display = set.length > 1 ? 'flex' : 'none';
        if (btnNext) btnNext.style.display = set.length > 1 ? 'flex' : 'none';
        return;
      }

      if (
        e.target.closest('[data-vana-modal-close]') ||
        e.target === modal.querySelector('.vana-modal__backdrop')
      ) {
        modal.classList.remove('is-active');
        modal.setAttribute('aria-hidden', 'true');
        document.getElementById('vanaModalMedia').innerHTML = '';
      }
    });

    if (btnPrev) btnPrev.addEventListener('click', function (e) {
      e.stopPropagation(); nav(-1);
    });
    if (btnNext) btnNext.addEventListener('click', function (e) {
      e.stopPropagation(); nav(+1);
    });

    document.addEventListener('keydown', function (e) {
      if (!modal || modal.getAttribute('aria-hidden') === 'true') return;
      if (e.key === 'ArrowLeft')  nav(-1);
      if (e.key === 'ArrowRight') nav(+1);
      if (e.key === 'Escape') {
        modal.classList.remove('is-active');
        modal.setAttribute('aria-hidden', 'true');
        document.getElementById('vanaModalMedia').innerHTML = '';
      }
    });
  }());

}());
</script>
